# Копия этого файла должна быть в .env рядом с docker-compose.yml.

# HMAC-secret для валидации GitHub webhook подписи (X-Hub-Signature-256).
# Сгенерировать: openssl rand -hex 32
WEBHOOK_SECRET=

# GitHub Personal Access Token (fine-grained, read-only) для клона приватных репо.
# Нужен, так как часть продуктовых репо приватные (iDryer-portal, iDryer-Link и др.).
# Создать: https://github.com/settings/personal-access-tokens/new
#   Resource owner: pavluchenkor
#   Repository access: Only select repositories → docs-idryer-org + приватные продуктовые репо
#   Repository permissions: Contents — Read-only, Metadata — Read-only
#   Expiration: максимально разрешённое (до 1 года)
GITHUB_TOKEN=

# Домен сайта для canonical url / sitemap (mkdocs site_url).
#   Стейджинг: https://new.docs.idryer.org/
#   Прод:      https://docs.idryer.org/
# Если не задан — берётся дефолт из mkdocs.yml (https://docs.idryer.org/).
SITE_URL=https://new.docs.idryer.org/
