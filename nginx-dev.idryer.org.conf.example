server {
    listen 443 ssl http2;
    server_name dev.idryer.org;

    ssl_certificate     /etc/letsencrypt/live/dev.idryer.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/dev.idryer.org/privkey.pem;

    root /opt/idryer-docs/site;
    index index.html;

    location / {
        try_files $uri $uri/ $uri.html =404;
    }

    location /hooks/ {
        proxy_pass http://127.0.0.1:9001/hooks/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 80;
    server_name dev.idryer.org;
    location /.well-known/acme-challenge/ { root /var/www/certbot; }
    location / { return 301 https://$host$request_uri; }
}
